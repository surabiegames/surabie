# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional OAuth; leave empty for email-only. Not dev-* when enabling GitHub login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional; improves GitHub API rate limits for the marketing page star counter.
GITHUB_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://surabie:surabie@localhost:5433/surabie?schema=public"

# -----------------------------------------------------------------------------
# Email (Postmark)
# -----------------------------------------------------------------------------
# e.g. Surabie <noreply@example.com>
SMTP_FROM=

# Use dev-* locally to log magic links to the terminal instead of sending email.
POSTMARK_API_TOKEN=

# Numeric Postmark template IDs (required when POSTMARK_API_TOKEN is not dev-*).
POSTMARK_SIGN_IN_TEMPLATE=
POSTMARK_ACTIVATION_TEMPLATE=

# -----------------------------------------------------------------------------
# Subscriptions (Stripe)
# -----------------------------------------------------------------------------
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PLAN_ID=